```text
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /services/{serviceId} {
      allow read: if true;   
      allow write: if false; 
    }
    match /users/{userId} {
      allow read, write: if false;
    }
    match /orders/{orderId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
```